!************************************************************************** 
!! ## INITIAL MUTATIONS
!************************************************************************** 
!-------------------
!! ### NOMINATIVE SINGULAR 
!-------------------
LEXICON Nom-sg-initial !!≈ - @CODE@ 
NounSéUrú;		 !!≈ - @CODE@ 
+DefArt:^Sé^tv^ts	#; 	!! definite article eg. an cat (m) (p38 NIG)
			!! an t-éan(m) - the bird (p39 NIG) 
			!! an bhróg(f) - the shoe
			!! initial mutation for other reasons
			!! e.g. comp. preps. ar an gcnoc, poss. mo chat

!! ^IM = initial mutation e.g. with prepositions, and possession
!! Singular:
!! e.g. ar an bhosca, ar an mbosca
!! possessive markers on vowels: ár n-athair, a (f) hathair, 
!! Plural:
!! e.g. ar bhoscaí, i mboscaí
!! possessive e.g. ár n-aithreacha - our fathers (^C)

LEXICON NounSéUrú !!≈ - @CODE@ 
#;			!" indefinite => no initial mutation
Emphasis; !!≈ - @CODE@ 
+Ecl:^IM^Urú	Emphasis;		 !!≈ - @CODE@ 
+Len:^IM^Sé	Emphasis;		
+hPref:^IM^hv	Emphasis;	!! adds ^h to vowel-initial words ...  but adds the +hPref to all words ... see fix file
					

LEXICON Emphasis !!≈ - @CODE@ 
#; !!≈ - @CODE@ 
+Emph:s^Emph	#;   			 !!≈ - @CODE@   NEEDS 1PL NE/NA & 3PL SEAN/SAN ALSO
!!! added 8/5/2014 EUD for theach-sa etc.
+Emph:%-s^Emph	#;   			!  NEEDS 1PL NE/NA & 3PL SEAN/SAN ALSO	


!-------------------
!! ### GENITIVE SINGULAR 
!-------------------

LEXICON Gen-sg-initial !!≈ - @CODE@ 
NounSéUrú;			! eg. tábhacht a n-oidhreachta
#; 			! eg. bia cait, bia sagairt, bia stóir, 
			!     bia rúin, pobail  
			!     siopa grósaera - a grocer's shop
+DefArt:^Sé^hv^ts	#; 	! eg. bia an chait,an íl, bia an stóir 
			!     bia an éin (the bird's food)
			! eg. bia an tsagairt (overgenerates 
			!     tshagairt, h will be removed,
			! eg. bia an rúin, an phobail
			! eg. siopa an ghrósaera - the grocer's shop
!-------------------
!! ### VOCATIVE SINGULAR 
!-------------------
!! Since this is trivial (always ^Sé) it is included with Final Mutations
!! in Voc-sg-0 and Voc-sg-1.
					
!------------
!! ### ALL PLURALS
!------------
!! Note: Vocative Plural does not require Def & Idf but it is easier to generate 
!! them and remove all Voc Pl Idfs at the end (the Def form is correct 
!! although the Def marker is unnecessary)

LEXICON Pl-initial !!≈ - @CODE@ 
+DefArt:^Sé^Urú^hv			#; 	! eg. na cait (m)
NounSéUrú;					! optional initial mutations for posession, after prepositions

!************************************************************************** 
!! ## FINAL MUTATIONS
!************************************************************************** 
!-------------------
!! ### NOMINATIVE SINGULAR
!-------------------
LEXICON Nom-sg !!≈ - @CODE@ 
+Sg:0	Nom-sg-initial; !!≈ - @CODE@ 

!-------------------
!! ### GENITIVE SINGULAR 
!-------------------

LEXICON Gen-sg-D1		 !!≈ - @CODE@  1st. Declension - Caolú (Slenderise)
+Sg:^Caol	Gen-sg-initial; !!≈ - @CODE@ 

LEXICON Gen-sg-D2		 !!≈ - @CODE@  2nd. Declension - Caolú (Slenderise) and
				! Add "e"
+Sg:^Caole	Gen-sg-initial;

LEXICON Gen-sg-D2a		 !!≈ - @CODE@  2nd. Declension - each -> í, ach -> aí 
				! tintreach - tintrí 
+Sg:^Ath	Gen-sg-initial;

LEXICON Gen-sg-D3		 !!≈ - @CODE@  3rd. Declension -  Broaden (Leathnú) and
				! Add "a"
+Sg:^Leaa	Gen-sg-initial;


LEXICON Gen-sg-D4		 !!≈ - @CODE@  4th. Declension - No change
+Sg:0	Gen-sg-initial;

LEXICON Gen-sg-D5-1		 !!≈ - @CODE@  5th. Declension - (Broaden) + ach
+Sg:^Leaach	Gen-sg-initial;
LEXICON Gen-sg-D5-2		 !!≈ - @CODE@  5th. Declension - Sync + (e)ach
+Sg:^Coim^VHach	Gen-sg-initial;
LEXICON Gen-sg-D5-2a		 !!≈ - @CODE@  5th. Declension - Sync + a
+Sg:^Coim^VHa	Gen-sg-initial;
LEXICON Gen-sg-D5-2b		 !!≈ - @CODE@  5th. Declension - Sync + Slen + e
+Sg:^Coim^Caole	Gen-sg-initial;
LEXICON Gen-sg-D5-3		 !!≈ - @CODE@  5th. Declension - Add "n"
+Sg:n		Gen-sg-initial;
LEXICON Gen-sg-D5-4		 !!≈ - @CODE@  5th. Declension - Add "d"
+Sg:d		Gen-sg-initial;
LEXICON Gen-sg-D5-5		 !!≈ - @CODE@  5th. Declension -  Broaden (Leathnú)
+Sg:^Lea	Gen-sg-initial;
LEXICON Gen-sg-D5-6		 !!≈ - @CODE@  5th. Declension -  Change + ithe
+Sg:^Athithe	Gen-sg-initial;
LEXICON Gen-sg-D5-7		 !!≈ - @CODE@  5th. Declension -  Change + Slen + the
+Sg:^Ath^Caolthe	Gen-sg-initial;
LEXICON Gen-sg-D5-8		 !!≈ - @CODE@  5th. Declension -  Change + Slen + te
+Sg:^Ath^Caolte	Gen-sg-initial;
LEXICON Gen-sg-D5-9		! 5th. Declension -  Change + tha
+Sg:^Aththa	Gen-sg-initial;
LEXICON Gen-sg-D5-10		! 5th. Declension -  Change + ta
+Sg:^Athta	Gen-sg-initial;

!-------------------
!! ### VOCATIVE SINGULAR 
!-------------------

LEXICON Voc-sg-0 !!≈ - @CODE@ 
+Sg+Len:^Sé		#;	 !!≈ - @CODE@  eg. a rún, a phobal

LEXICON Voc-sg-1 !!≈ - @CODE@ 
+Sg+Len:^Caol^Sé	#; 	! eg. a éin - O bird!
				!     a chait, a íl 
				! eg. a shagairt 

LEXICON Voc-initial
+Len:^IM^Sé		#;	! Jul 2012 added +Len

!-------------------------------------------------------------------------
!-------------------
!! ### ALL PLURALS
!-------------------


LEXICON PL-TADA					 !!≈ - @CODE@  NO CHANGE (LIT. NOTHING)
+Pl:0		Pl-initial;


LEXICON PL-CAOLÚ				 !!≈ - @CODE@  CAOLÚ (SLENDERISE)
+Pl:^Caol	Pl-initial;


LEXICON PL-LEATHNÚ				 !!≈ - @CODE@  LEATHNÚ (BROADEN)
+Pl:^Lea	Pl-initial;


LEXICON PL-(LEA)A				 !!≈ - @CODE@  ADD "A" & LEATHNÚ (BROADEN) IF SLENDER
+Pl:^Leaa	Pl-initial;


LEXICON PL-TA					 !!≈ - @CODE@  ADD "TA"
+Pl:ta		Pl-initial;


LEXICON PL-(LEA)THA				 !!≈ - @CODE@  ADD "THA" & LEATHNÚ IF SLENDER
+Pl:^Leatha	Pl-initial;


LEXICON PL-(E)ANNA				 !!≈ - @CODE@  ADD "ANNA" IF BROAD & ADD "EANNA" IF SLENDER
+Pl:^VHanna	Pl-initial;


LEXICON PL-Í					 !!≈ - @CODE@  ADD "Í"
+Pl:í		Pl-initial;

LEXICON PL-TÍ					 !!≈ - @CODE@  ADD "TÍ"
+Pl:tí		Pl-initial;


LEXICON PL-(CAOL)E				 !!≈ - @CODE@  ADD "E" & CAOLÚ IF BROAD
+Pl:^Caole	Pl-initial;


LEXICON PL-(CAOL)EACHA			!!≈ - @CODE@  ADD "EACHA" & CAOLÚ
+Pl:^Caoleacha	Pl-initial;

LEXICON PL-(LEA)ACHA			!!≈ - @CODE@  ADD "ACHA" & LEATHNÚ
+Pl:^Leaacha	Pl-initial;


LEXICON PL-(E)ACHA				!!≈ - @CODE@  ADD "ACHA" IF BROAD & ADD "EACHA" IF SLENDER
+Pl:^VHacha	Pl-initial;


LEXICON PL-THANNA				!!≈ - @CODE@  ADD "THANNA"
+Pl:thanna	Pl-initial;

LEXICON PL-TE					!!≈ - @CODE@  ADD "TE"
+Pl:te		Pl-initial;


LEXICON PL-AÍ					!!≈ - @CODE@  ADD "AÍ"
+Pl:aí		Pl-initial;


LEXICON PL-NNA					!!≈ - @CODE@  ADD "NNA"
+Pl:nna		Pl-initial;


LEXICON PL-THE					!!≈ - @CODE@  ADD "THE"
+Pl:the		Pl-initial;


LEXICON PL-NA					!!≈ - @CODE@  ADD "NA"
+Pl:na		Pl-initial;


LEXICON PL-IDÍ					!!≈ - @CODE@  ADD "IDÍ"
+Pl:idí		Pl-initial;


LEXICON PL-ATHRÚ				!!≈ - @CODE@  ATHRÚ (CHANGE LAST SYLLABLE)
+Pl:^Ath	Pl-initial;

LEXICON PL-(E)ANTA				!!≈ - @CODE@  ADD "ANTA" IF BROAD & ADD "EANTA" IF SLENDER
+Pl:^VHanta	Pl-initial;

LEXICON PL-ITE					!!≈ - @CODE@  ADD "ITE"
+Pl:ite		Pl-initial;

LEXICON PL-ONNA					!!≈ - @CODE@  ADD "ONNA"
+Pl:onna		Pl-initial;

LEXICON PL-OCHA					!!≈ - @CODE@  ADD "OCHA"
+Pl:ocha		Pl-initial;

!---------------------------------------------------------------------------

!**************************************************************************
! ## Moirfeolaíocht na nAinmfhocail Gaeilge (Morphology of Irish Nouns)
!**************************************************************************
!!	###	PROPER NOUNS
!**************************************************************************
!! E. Uí Dhonnchadha 
!  
! April 2003: ^IM general initial mutation flag
!
!! ADDED THE +SG TAG 20/2/2004
!! ADDED NP-Fam Aug 2004
!**************************************************************************  
!**************************************************************************  
!!				CONTINUATION CLASSES
!**************************************************************************  


LEXICON NP-PLACE !!≈ - @CODE@ 
+Place+Prop+Noun+Masc:	NpSéUrú;

! not necessary?
!LEXICON NP-PLACE-EN-fem
!+Place+Prop+Noun+Fem:		NpSéUrú-EN;

LEXICON NP-PLACE-EN !!≈ - @CODE@ 
+Place+Prop+Noun+Masc:	NpSéUrú-EN;

LEXICON NP-PLACE-sg !!≈ - @CODE@ 
+Place+Prop+Noun+Masc:	NpSéUrú;
+Adj+Base+DeNom:^VHach	NpSéUrú;

LEXICON NP-PLACE-fem !!≈ - @CODE@ 
+Place+Prop+Noun+Fem:		NpSéUrú-fem;
+Adj+Base+DeNom:^VHach	NpSéUrú;

LEXICON NP-PLACE-pl !!≈ - @CODE@ 
+Place+Prop+Noun+Masc:	NpSéUrú-PL;

LEXICON NP-FAM-EN !!≈ - @CODE@ 
!+Fam+Prop+Noun+Masc:	NpSéUrú;
+Fam+Prop+Noun+Masc:	NpSéUrú-EN;

LEXICON NP-PERS-EN-fem !!≈ - @CODE@ 
!+PersName+Prop+Noun+Fem:	NpSéUrú;
+PersName+Prop+Noun+Fem:	NpSéUrú-EN;

LEXICON NP-PERS-EN !!≈ - @CODE@ 
!+PersName+Prop+Noun+Masc:	NpSéUrú;
+PersName+Prop+Noun+Masc:	NpSéUrú-EN;


LEXICON NP-Fam !!≈ - @CODE@ 
+Fam+Prop+Noun+Masc+Com+Sg+hPref:^IM^hv		#;
+Fam+Prop+Noun+Masc+Gen+Sg:^M^G^Caol^hv^ts		#; ! ^Caol not yet tested
+Fam+Prop+Noun+Fem+Gen+Sg+Len:^IM^Sé		#;
!+Prop+Noun+Masc+Gen+Sg:^M^G^Sé		#;
+Fam+Prop+Noun+Masc+Com+Sg+DefArt:^M^C^Lea^tv^VHach		#;

LEXICON NP-Fam-0 !!≈ - @CODE@ 
+Fam+Prop+Noun+Masc+Com+Sg+hPref:^IM^hv		#;
+Fam+Prop+Noun+Masc+Gen+Sg:^M^G^hv^ts		#;
+Fam+Prop+Noun+Fem+Gen+Sg+Len:^IM^Sé		#;
+Fam+Prop+Noun+Masc+Com+Sg+DefArt:^IM^tv		#;

LEXICON NP-Fam-V !!≈ - @CODE@ 
+Fam+Prop+Noun+Masc+Com+Sg+hPref:^IM^hv		#;
+Fam+Prop+Noun+Masc+Gen+Sg:^M^G^hv^ts		#;
+Fam+Prop+Noun+Fem+Gen+Sg+Len:^IM^Sé		#;
+Fam+Prop+Noun+Masc+Com+Sg+DefArt:^IM^tvch	#;

LEXICON NP-Fam-chg !!≈ - @CODE@ 
+Fam+Prop+Noun+Masc+Com+Sg+hPref:^IM^hv		#;
+Fam+Prop+Noun+Masc+Gen+Sg:^M^G^hv^ts		#;
+Fam+Prop+Noun+Fem+Gen+Sg+Len:^IM^Sé		#;
+Fam+Prop+Noun+Masc+Com+Sg+DefArt:^Ath^IM^tv	#;

!! when it is a place name
!! as well as the usual inflections for propernouns  (4 classes)
!! we want to generate an adjectival form e.g. Beilg - Beilgeach


!! new 5-6-2024
!! Place and Personal name files both use Nf1-Prop and Nm1-Prop etc.
!
! currently not used
!LEXICON Nf1-Prop-Place
!+Place:		Nf1-Prop;

LEXICON Nf2-Prop-Place !!≈ - @CODE@ 
+Place:		Nf2-Prop;

LEXICON Nf3-Prop-Place !!≈ - @CODE@ 
+Place:		Nf3-Prop;

LEXICON Nf4-Prop-Place !!≈ - @CODE@ 
+Place:		Nf4-Prop;

LEXICON Nf5-Prop-Place !!≈ - @CODE@ 
+Place:		Nf5-Prop;

LEXICON Nm1-Prop-Place !!≈ - @CODE@ 
+Place:		Nm1-Prop;

! currently not used
!LEXICON Nm2-Prop-Place
!+Place:		Nm2-Prop;

! currently not used
!LEXICON Nm3-Prop-Place
!+Place:		Nm3-Prop;

LEXICON Nm4-Prop-Place !!≈ - @CODE@ 
+Place:		Nm4-Prop;

! currently not used
!LEXICON Nm5-Prop-Place
!+Place:		Nm5-Prop;



LEXICON Nm1-Prop-PName !!≈ - @CODE@ 
+PersName:		Nm1-Prop;

! currently not used
!LEXICON Nm2-Prop-PName
!+PersName:		Nm2-Prop;

LEXICON Nm3-Prop-PName !!≈ - @CODE@ 
+PersName:		Nm3-Prop;

LEXICON Nm4-Prop-PName !!≈ - @CODE@ 
+PersName:		Nm4-Prop;

! currently not used
!LEXICON Nm5-Prop-PName
!+PersName:		Nm5-Prop;

! used for MWE names without inflection
!LEXICON Nf1-Prop-PName
!+PersName:		Nf1-Prop;

LEXICON Nf2-Prop-PName !!≈ - @CODE@ 
+PersName:		Nf2-Prop;

LEXICON Nf3-Prop-PName !!≈ - @CODE@ 
+PersName:		Nf3-Prop;

LEXICON Nf4-Prop-PName !!≈ - @CODE@ 
+PersName:		Nf4-Prop;

! currently not used
!LEXICON Nf5-Prop-PName
!+PersName:		Nf5-Prop;


!! masc nouns - slenderise
LEXICON Nm1-Prop !!≈ - @CODE@ 
+Prop+Noun+Masc+Com:^M^C			Sing;
+Prop+Noun+Masc+Gen:^M^G^Caol	IMGen;
+Prop+Noun+Masc+Voc:^M^V^Caol	Seimh;
+Adj+Base+DeNom:^VHach	NpSéUrú-TIR;

!! fem nouns - slenderise and add e
LEXICON Nf2-Prop !!≈ - @CODE@ 
+Prop+Noun+Fem+Com:^F^C			Sing;
+Prop+Noun+Fem+Gen:^F^G^Caole	IMGen;
+Prop+Noun+Fem+Voc:^F^V			Seimhiu;
+Adj+Base+DeNom:^VHach	NpSéUrú-TIR;


!! fem nouns - broaden and add a
LEXICON Nf3-Prop !!≈ - @CODE@ 
+Prop+Noun+Fem+Com:^F^C			Sing;
+Prop+Noun+Fem+Gen:^F^G^Leaa	IMGen;
+Prop+Noun+Fem+Voc:^F^V		Seimhiu;
+Adj+Base+DeNom:^VHach	NpSéUrú-TIR;

LEXICON Nm3-Prop
+Prop+Noun+Masc+Com:^M^C			Sing;
+Prop+Noun+Masc+Gen:^M^G^Leaa	IMGen;
+Prop+Noun+Masc+Voc:^M^V		Seimhiu;

 
!! fem nouns - no change
LEXICON Nf4-Prop
+Prop+Noun+Fem+Com:^F^C			Sing;
+Prop+Noun+Fem+Gen:^F^G			IMGen;
+Prop+Noun+Fem+Voc:^F^V			Seimhiu;
+Adj+Base+DeNom:^VHach	NpSéUrú-TIR;


!! masc nouns - no change

LEXICON Nm4-Prop
+Prop+Noun+Masc+Com:^M^C			Sing;
+Prop+Noun+Masc+Gen:^M^G		IMGen;
+Prop+Noun+Masc+Voc:^M^V		Seimhiu;
+Adj+Base+DeNom:^VHach	NpSéUrú-TIR;

!! fem nouns - Albain/na hAlban
LEXICON Nf5-Prop
+Prop+Noun+Fem+Com:^F^C			Sing;
+Prop+Noun+Fem+Gen:^F^G^Lea		IMGen;
+Prop+Noun+Fem+Voc:^F^V			Seimhiu;
+Adj+Base+DeNom:^VH^Leaach	NpSéUrú-TIR;


LEXICON IMGen
#;
0:^hv^ts			Seimhiu;

LEXICON Seimh
+Len:^Sé		#;

LEXICON Seimhiu
+Len:^IM^Sé		#;

LEXICON Sing
+Sg:0				#;
+Sg+Len:^IM^Sé			#;
+Sg+Ecl:^IM^Urú			#;
! ??? don't need DefArt with proper nouns - mostly?
!+Sg+DefArt:^Sé^tv^ts		#;

LEXICON NpSéUrú-fem
+Com+Sg:			#; 
+Com+Sg+Len:^IM^Sé		#; 
+Gen+Sg+hPref:^IM^hve		#;  ! muintir na háite
+Com+Sg+Ecl:^IM^Urú		#;
+Gen+Sg+Ecl:^IM^Urú		#;

LEXICON NpSéUrú
+Com+Sg:	#; 
+Com+Sg+Len:^IM^Sé		#; 
+Gen+Sg+Len:^IM^Sé		#; 
+Com+Sg+Ecl:^IM^Urú		#;
+Gen+Sg+Ecl:^IM^Urú		#;

LEXICON NpSéUrú-EN
+Com+Sg:	#; 
+Com+Sg+Len:^IM^Sé		#; 
+Com+Sg+Ecl:^IM^Urú		#;

LEXICON NpSéUrú-PL
+Com+Pl:	#; 
+Com+Pl+Len:^IM^Sé		#; 
+Com+Pl+Ecl:^IM^Urú		#;

! not used
!LEXICON NP-X
!+Prop+Noun:	#;

LEXICON NpSéUrú-TIR
#;
+Len:^IM^Sé		#;
+Ecl:^IM^Urú		#;
+DefArt:^Sé^tv^ts	#;

LEXICON AdjF-Prop
+Adj+Fem+Com+Sg+Len:	#;

! no plural feminine placenemes in lexicon file so far
!LEXICON AdjF-Prop-pl
!+Adj+Fem+Com+Pl:	#;

LEXICON AdjM-Prop
+Adj+Masc+Com+Sg:	#;

LEXICON AdjM-Prop-pl
+Adj+Masc+Com+Pl:	#;

